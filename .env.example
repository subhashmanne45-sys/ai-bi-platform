# ============================================================
# AI-Powered BI Platform — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bi_platform
DB_USER=bi_user
DB_PASSWORD=your_password_here

# Full connection URL (auto-built from above, or override)
DATABASE_URL=postgresql://bi_user:your_password_here@localhost:5432/bi_platform

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_SALES=sales_events
KAFKA_TOPIC_CUSTOMERS=customer_events
KAFKA_TOPIC_INVENTORY=inventory_events

# --- Airflow ---
AIRFLOW_HOME=./orchestration
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-this-to-a-random-secret

# --- Streamlit ---
STREAMLIT_PORT=8501

# --- Data Generator ---
DATA_OUTPUT_DIR=./data/raw
RECORDS_PER_RUN=1000
STREAMING_INTERVAL_SECONDS=2

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=./logs
